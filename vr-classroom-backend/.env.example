# 数据库配置
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/vr_classroom?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=your_database_username
SPRING_DATASOURCE_PASSWORD=your_database_password

# OSS配置
OSS_ENDPOINT=oss-cn-wuhan-lr.aliyuncs.com
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET_NAME=vr-classroom-bucket

# JWT配置
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long

# 服务器配置
SERVER_PORT=8080

# 默认环境
SPRING_PROFILES_ACTIVE=dev

# 微信登录配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# Redis 配置
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=your_redis_password
SPRING_REDIS_DATABASE=your_redis_database_index

# 文件上传配置（可选，用于服务器环境）
# FILE_UPLOAD_SERVER_PATH=/opt/1panel/apps/openresty/openresty/www/sites/vr-static/index
# FILE_ACCESS_URL=/assets
# FILE_STATIC_PATH=/assets/**
# FILE_STATIC_LOCATION=file:/opt/1panel/apps/openresty/openresty/www/sites/vr-static/index/

